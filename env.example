# InsForge Configuration
# Get these values from your InsForge dashboard: https://insforge.dev

# Your InsForge backend URL (required for authentication)
VITE_INSFORGE_BASE_URL=https://6aiag3ra.us-east.insforge.app

# Anonymous key (optional, only needed for database/storage operations)
VITE_INSFORGE_ANON_KEY=your_insforge_anon_key_here

# Vite dev server allowed hosts (comma-separated, for ngrok/tunneling)
VITE_ALLOWED_HOSTS=localhost

# ⚠️ CRITICAL: Set these in InsForge dashboard — NEVER commit real values to git.
# Edge functions read them at runtime. Replace with your actual values.

# Web Payment Gateway base URL (PG = Payment Gateway, used for redirect + verification)
# UAT: https://uat-new-clientapi.fonepay.com | Prod: https://clientapi.fonepay.com
FONEPAY_PG_URL=https://clientapi.fonepay.com
FONEPAY_PG_MERCHANT_CODE=your_merchant_code_here
FONEPAY_PG_MERCHANT_SECRET=your_merchant_secret_here
# Must be the full callback URL (e.g. https://your-site.com/payment-result)
FONEPAY_PG_CALLBACK_URL=https://your-domain.com/payment-result

# Fonepay API base URLs (config, not secrets)
# UAT: https://uat-new-merchant-api.fonepay.com
# Prod: https://merchantapi.fonepay.com
FONEPAY_MERCHANT_BASE=https://merchantapi.fonepay.com
# UAT: https://uat-new-clientapi.fonepay.com
# Prod: https://clientapi.fonepay.com
FONEPAY_CLIENT_BASE=https://clientapi.fonepay.com
FONEPAY_USERNAME=your_fonepay_username_here
FONEPAY_PASSWORD=your_fonepay_password_here

# Client URL for redirects
CLIENT_URL=https://your-domain.com

# Email notifications (Resend)
# Sign up at https://resend.com to get an API key
RESEND_API_KEY=
EMAIL_FROM=Highlands Motel <noreply@highlands-motel.com>

# ─────────────────────────────────────────────
# POS Synchronization Configuration
# ─────────────────────────────────────────────

# API Key that the POS system must send in X-POS-API-Key header
# Generate with: openssl rand -hex 32
POS_SYNC_API_KEY=

# Webhook URL where sync events are delivered to the POS system
# e.g. https://pos.your-domain.com/api/webhooks/highlands
POS_WEBHOOK_URL=

# Shared secret for HMAC-SHA256 webhook payload signing
# The POS system verifies the X-Webhook-Signature header
# Generate with: openssl rand -hex 32
POS_WEBHOOK_SECRET=

# InsForge URL (for edge function DB client)
INSFORGE_URL=https://your-app.region.insforge.app

# Supabase/InsForge service role key (for sync-webhook-sender and fonepay-payment functions)
SUPABASE_SERVICE_ROLE_KEY=
INSFORGE_SERVICE_ROLE_KEY=

# API key for triggering payment reconciliation endpoint (optional security)
# The reconciler endpoint checks this against the x-reconcile-key header
RECONCILE_API_KEY=

