# InsForge Configuration
# Get these values from your InsForge dashboard: https://insforge.dev

# Your InsForge backend URL (required for authentication)
VITE_INSFORGE_BASE_URL=https://6aiag3ra.us-east.insforge.app

# Anonymous key (optional, only needed for database/storage operations)
VITE_INSFORGE_ANON_KEY=your_insforge_anon_key_here

# Vite dev server allowed hosts (comma-separated, for ngrok/tunneling)
VITE_ALLOWED_HOSTS=localhost

# Fonepay Payment Gateway (set these in InsForge dashboard — edge functions read them at runtime)
# Dev: https://dev-clientapi.fonepay.com | Prod: https://clientapi.fonepay.com
FONEPAY_PG_URL=https://clientapi.fonepay.com
FONEPAY_PG_MERCHANT_CODE=PLACEHOLDER_MERCHANT_CODE
FONEPAY_PG_MERCHANT_SECRET=PLACEHOLDER_MERCHANT_SECRET
FONEPAY_PG_CALLBACK_URL=https://highlands-motel.com/payment-result

# Fonepay Dynamic QR
# Dev: https://dev-merchantapi.fonepay.com/convergent-merchant-web/api/merchant/merchantDetailsForThirdParty
# Prod: https://merchantapi.fonepay.com/api/merchant/merchantDetailsForThirdParty
FONEPAY_DYNAMICQR_URL=https://merchantapi.fonepay.com/api/merchant/merchantDetailsForThirdParty
FONEPAY_USERNAME=9829006916
FONEPAY_PASSWORD=Highlands@123

# Client URL for redirects
CLIENT_URL=https://highlands-motel.com

# Email notifications (Resend)
# Sign up at https://resend.com to get an API key
RESEND_API_KEY=
EMAIL_FROM=Highlands Motel <noreply@highlands-motel.com>

# ─────────────────────────────────────────────
# POS Synchronization Configuration
# ─────────────────────────────────────────────

# API Key that the POS system must send in X-POS-API-Key header
# Generate with: openssl rand -hex 32
POS_SYNC_API_KEY=

# Webhook URL where sync events are delivered to the POS system
# e.g. https://pos.your-domain.com/api/webhooks/highlands
POS_WEBHOOK_URL=

# Shared secret for HMAC-SHA256 webhook payload signing
# The POS system verifies the X-Webhook-Signature header
# Generate with: openssl rand -hex 32
POS_WEBHOOK_SECRET=

# InsForge URL (for edge function DB client)
INSFORGE_URL=https://your-app.region.insforge.app

# Supabase/InsForge service role key (for sync-webhook-sender and fonepay-payment functions)
INSFORGE_SERVICE_ROLE_KEY=

